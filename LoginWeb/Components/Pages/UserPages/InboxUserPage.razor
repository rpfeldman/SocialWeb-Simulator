@page "/user/{ID:int}/inbox"
@using LoginWeb.Components.Tags
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject LoginSecurityService LSS
@inject IMessageContainer<MSModel.Message, int> container
@inject ViewProjectionService VPS

<PageTitle>Bandeja</PageTitle>

<div style="
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0f172a, #1e3a8a, #0f172a);
    padding: 40px;
    box-sizing: border-box;
    font-family: Arial, Helvetica, sans-serif;
    ">

    <div style="
        width: 100%;
        max-width: 600px;
        background: rgba(255,255,255,0.96);
        border-radius: 22px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.30);
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.25);
        text-align: center;
        ">

        <!-- HEADER -->
        <div style="
            padding: 30px 35px 20px 35px;
            background:
            linear-gradient(to bottom, #ef4444, #ef4444) 6px center / 5px 100% no-repeat,
            linear-gradient(to bottom, #ef4444, #ef4444) calc(100% - 6px) center / 5px 100% no-repeat,
            linear-gradient(135deg, #4ade80, #22c55e);
            color: white;
            ">
            <div style="
                font-size: 28px;
                font-weight: bold;
                margin-bottom: 6px;
                ">
                Bandeja de Entrada
            </div>
            <div style="
                font-size: 15px;
                opacity: 0.9;
                ">
                Tienes @NewMessages() mensajes nuevos!
            </div>
        </div>

        <!-- MENSAJES -->
        <div style="
            padding: 25px 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            ">
            @MessagesBoard
        </div>

        <!-- BOTONES -->
        <div style="
            padding: 0 30px 30px 30px;
            display: flex;
            gap: 14px;
            justify-content: center;
            ">

            <button @onclick="MarkAllAsRead" style="
                flex: 1;
                padding: 12px;
                border: none;
                border-radius: 12px;
                background: linear-gradient(135deg, #2563eb, #1d4ed8);
                color: white;
                font-size: 14px;
                font-weight: bold;
                cursor: pointer;
                box-shadow: 0 6px 14px rgba(37,99,235,0.35);
                ">
                Marcar todo como leido
            </button>

            <button @onclick="Navigate" style="
                flex: 1;
                padding: 12px;
                border: none;
                border-radius: 12px;
                background: #e2e8f0;
                color: #0f172a;
                font-size: 14px;
                font-weight: bold;
                cursor: pointer;
                box-shadow: 0 6px 14px rgba(0,0,0,0.10);
                ">
                Volver!
            </button>

        </div>
    </div>
</div>


@code 
{
    [Parameter]
    public int ID { get; set; }

    private UserMessagesService? UMS;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        UMS = new(container, ID);
    }
    protected override void OnAfterRender(bool FirstRender)
    {
        base.OnAfterRender(FirstRender);

        if (FirstRender)
        {
            Action action = LSS.IsAuthorized ? new Action(() => { LSS.UnauthorizeLogin(); }) : new Action(() => { NavigationManager.NavigateTo("/Error/ForbiddenAcces", replace: true); });
            action.Invoke();
        }
    }

    int NewMessages()
    {
        return UMS!.GetUserMessages().Count;
    }

    void MarkAllAsRead()
    {
        Console.Beep();
        UMS!.MarkAllAsRead();
    }

    RenderFragment MessagesBoard => _builder =>
    {
        if (UMS!.GetUserMessages().Count < 1)
        {
            _builder.OpenElement(0, "div");
            _builder.AddContent(1, "No hay mensajes para mostrar!");
            _builder.CloseElement();
            return;   
        };

        foreach (var item in UMS!.GetUserMessages())
        {
            _builder.OpenComponent<MessageTag>(0);
            _builder.AddComponentParameter(1, "Message", item.MessageText);
            _builder.AddComponentParameter(2, "Sender", VPS.GetUser(item.SenderId)!.Username);
            _builder.AddComponentParameter(2, "OnClick", new Action(() =>
            {
                UMS!.MarkAsRead(item.MessageId);
                StateHasChanged();
            }));

            _builder.CloseComponent();
        }
    };

    async void Navigate()
    {
        LSS.AuthorizeLogin();
        NavigationManager.NavigateTo($"/User/{ID}");
    }
}
