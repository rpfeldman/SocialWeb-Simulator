@page "/User/{ID:int}"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject ViewProjectionService VPS
@inject LoginSecurityService LSS

<div style="
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0f172a, #1e3a8a, #0f172a);
    padding: 40px;
    box-sizing: border-box;
    font-family: Arial, Helvetica, sans-serif;
    ">

    <div style="
        width: 100%;
        max-width: 700px;
        background: rgba(255,255,255,0.96);
        border-radius: 22px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.30);
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.25);
        text-align: center;
        ">

        <!-- HEADER -->
        <div style="
            padding: 30px 35px 20px 35px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: white;
            ">
            <div style="
                font-size: 28px;
                font-weight: bold;
                margin-bottom: 6px;
                ">
                User Panel
            </div>

            <div style="
                font-size: 15px;
                opacity: 0.9;
                ">
                Manage your account
            </div>
        </div>

        <!-- CONTENIDO -->
        <div style="padding: 40px 30px;">

            <!-- BIENVENIDA -->
            <div style="
                font-size: 22px;
                font-weight: bold;
                color: #0f172a;
                margin-bottom: 30px;
                ">
                Welcome, @VPS.GetUser(ID)!.Username
            </div>

            <!-- CARD MENU -->
            <div style="
                display: inline-block;
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                border-radius: 18px;
                padding: 25px 30px;
                box-shadow: inset 0 1px 0 rgba(255,255,255,0.75);
                ">

                <div style="
                    font-weight: bold;
                    font-size: 18px;
                    margin-bottom: 20px;
                    color: #1e293b;
                    ">
                    Action Menu
                </div>

                <div style="
                    display: flex;
                    flex-direction: column;
                    gap: 14px;
                    align-items: center;
                    ">

                    
                    <button @onclick="() => { LSS.AuthorizeLogin(); NavigationManager.NavigateTo(URLs()[3]); }" style="
                        width: 220px;
                        padding: 12px;
                        border: none;
                        border-radius: 12px;
                        background: linear-gradient(135deg, #4ade80, #22c55e);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        box-shadow: 0 6px 14px rgba(74, 222, 128, 0.35);
                        ">
                        Send messages
                    </button>

                    <button @onclick="() => { LSS.AuthorizeLogin(); NavigationManager.NavigateTo(URLs()[4]); }" style="
                        width: 220px;
                        padding: 12px;
                        border: none;
                        border-radius: 12px;
                        background:
                        linear-gradient(to bottom, #ef4444, #ef4444) 6px center / 5px 100% no-repeat,
                        linear-gradient(to bottom, #ef4444, #ef4444) calc(100% - 6px) center / 5px 100% no-repeat,
                        linear-gradient(135deg, #4ade80, #22c55e);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        box-shadow: 0 6px 14px rgba(74, 222, 128, 0.35);
                        ">
                        View inbox
                    </button>
                    <br />
                    <button @onclick="() => { LSS.AuthorizeLogin(); NavigationManager.NavigateTo(URLs()[1]); }" style="
                        width: 220px;
                        padding: 12px;
                        border: none;
                        border-radius: 12px;
                        background: linear-gradient(135deg, #2563eb, #1d4ed8);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        box-shadow: 0 6px 14px rgba(37,99,235,0.35);
                        ">
                        Edit profile
                    </button>

                    <button @onclick="() => { LSS.AuthorizeLogin(); NavigationManager.NavigateTo(URLs()[2]); }" style="
                        width: 220px;
                        padding: 12px;
                        border: none;
                        border-radius: 12px;
                        background: linear-gradient(135deg, #ef4444, #dc2626);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        box-shadow: 0 6px 14px rgba(239,68,68,0.35);
                        ">
                        Delete profile
                    </button>

                    <button @onclick="() => { NavigationManager.NavigateTo(URLs()[0]); }" style="
                        width: 220px;
                        padding: 12px;
                        border: none;
                        border-radius: 12px;
                        background: #e2e8f0;
                        color: #0f172a;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        box-shadow: 0 6px 14px rgba(0,0,0,0.10);
                        ">
                        Log out
                    </button>

                </div>
            </div>
        </div>
    </div>
</div>

@code 
{
    [Parameter]
    public int ID { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
    }
    protected override void OnAfterRender(bool FirstRender)
    {
        base.OnAfterRender(FirstRender);

        if (FirstRender)
        {
            Action action = LSS.IsAuthorized ? new Action(() => { LSS.UnauthorizeLogin(); }) : new Action(() => { NavigationManager.NavigateTo("/Error/ForbiddenAcces", replace: true); });
            action.Invoke();
        }
    }

    string[] URLs()
    {
        return new string[] { "/", $"/User/{ID}/Update", $"/User/{ID}/Confirm", $"/user/{ID}/sendmessage", $"/user/{ID}/inbox" };
    }
}

        