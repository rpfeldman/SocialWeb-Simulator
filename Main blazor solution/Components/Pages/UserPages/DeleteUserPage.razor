@page "/User/{ID:int}/Delete"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject LoginSecurityService LSS
@inject ViewProjectionService VPS
@inject IUserDbRepo Repository


<div style="
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #0f172a, #7f1d1d, #0f172a);
    padding: 40px;
    box-sizing: border-box;
    font-family: Arial, Helvetica, sans-serif;
    ">
    <div style="
        width: 100%;
        max-width: 760px;
        background: rgba(255,255,255,0.97);
        border-radius: 22px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35);
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.25);
        text-align: center;
        ">
        <!-- HEADER -->
        <div style="
            padding: 30px 35px 22px 35px;
            background: linear-gradient(135deg, #dc2626, #991b1b);
            color: white;
            ">
            <div style="
                font-size: 30px;
                font-weight: bold;
                margin-bottom: 8px;
                letter-spacing: 0.3px;
                ">
                Delete profile
            </div>

            <div style="
                font-size: 15px;
                opacity: 0.92;
                ">
                Critical and irreversible action
            </div>
        </div>

        <!-- BODY -->
        <div style="padding: 36px 32px;">
            <div style="
                font-size: 22px;
                font-weight: bold;
                color: #b91c1c;
                margin-bottom: 22px;
                ">
                YOU ARE ABOUT TO DELETE YOUR PROFILE
            </div>

            <div style="
                max-width: 560px;
                margin: 0 auto 22px auto;
                padding: 18px 20px;
                border: 2px dashed #ef4444;
                background: #fef2f2;
                border-radius: 16px;
                color: #7f1d1d;
                font-size: 15px;
                line-height: 1.6;
                box-sizing: border-box;
                ">
                Warning: this decision is permanent and once confirmed it cannot be undone
            </div>

            <div style="
                font-size: 18px;
                color: #1e293b;
                font-weight: bold;
                margin-bottom: 28px;
                ">
                Do you want to continue?
            </div>

            <table style="
                margin: 0 auto;
                border-collapse: separate;
                border-spacing: 14px 0;
                ">
                <tr>
                    <td>
                        <button @onclick="Delete" style="
                            padding: 13px 22px;
                            border: none;
                            border-radius: 12px;
                            background: linear-gradient(135deg, #ef4444, #b91c1c);
                            color: white;
                            font-size: 15px;
                            font-weight: bold;
                            cursor: pointer;
                            box-shadow: 0 8px 18px rgba(239,68,68,0.35);
                            ">
                            Yes, continue
                        </button>
                    </td>

                    <td>
                        <button @onclick="() => Navigate()" style="
                            padding: 12px 18px;
                            border: none;
                            border-radius: 12px;
                            background: #e2e8f0;
                            color: #0f172a;
                            font-size: 14px;
                            font-weight: bold;
                            cursor: pointer;
                            box-shadow: 0 6px 14px rgba(0,0,0,0.10);
                            ">
                            No, go back
                        </button>
                    </td>
                </tr>
            </table>

            <div style="
                margin-top: 28px;
                text-align: center;
                ">
                <div style="
                    display: inline-block;
                    min-width: 260px;
                    max-width: 100%;
                    padding: 14px 18px;
                    border-radius: 14px;
                    background: #f8fafc;
                    border: 1px solid #cbd5e1;
                    color: #0f172a;
                    font-size: 15px;
                    box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
                    box-sizing: border-box;
                    white-space: pre-line;
                    ">
                    @Result
                </div>
            </div>
        </div>
    </div>
</div>

@code 
{
    [Parameter]
    public int ID { get; set; }
    UserProfileService? UPS;

    string Result = string.Empty;
    string name = string.Empty;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        UPS = new(ID, Repository);
        name = VPS.GetUser(ID)!.Username;
    }
    protected override void OnAfterRender(bool FirstRender)
    {
        base.OnAfterRender(FirstRender);

        if (FirstRender)
        {
            Action action = LSS.IsAuthorized ? new Action(() => { LSS.UnauthorizeLogin(); }) : new Action(() => { NavigationManager.NavigateTo("/Error/ForbiddenAcces", replace: true); });
            action.Invoke();
        }
    }

    void Delete()
    {
        UPS!.Delete();
        Result = $"Goodbye, {name}\nAccount successfully deleted!";
        StateHasChanged();
        UPS.Dispose();
        Navigate(true);
        return;
       
    }

    async void Navigate(bool delete = false)
    {
        if (delete) { await Task.Delay(1300); NavigationManager.NavigateTo("/"); return; }
     
         LSS.AuthorizeLogin();
        NavigationManager.NavigateTo($"/User/{ID}");
    }

}
