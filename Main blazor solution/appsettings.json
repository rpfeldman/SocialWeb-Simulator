{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "DataBase": {
    "ConnectionString": "", // Your SQLServer connection string 

    "UsernameMaxCharLimit": 30, // The maximum length you set in the column for usernames

    "UsernameMinCharLimit": 5, // The minimum length you want to set for the username

    "PasswordMaxCharLimit": 60, // The maximum length you set in the column for password

    "PasswordMinCharLimit": 5, // The minimum length you want to set for the password

    "MessageTextCharLimit": 150, // The maximum length you set in the column for messages

    "UserSystemImplementation": "Test", // Could be: Test (in-memory database), Dapper or Entity_framework [recommended]

    "MessageSystemImplementation": "Test" // Could be: Test (in-memory database) or Entity_framework [recommended]

    // NOTE: If both systems share the same persistence layer, ensure they use the same database implementation (e.g., both in-memory or both persistent) to avoid state inconsistency.
  }
}
